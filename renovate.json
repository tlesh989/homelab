{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "baseBranches": [
    "main"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Automerge pinning and digest updates",
      "matchUpdateTypes": [
        "pinning",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Group minor and patch updates for Terraform providers",
      "matchManagers": [
        "terraform"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "terraform minor/patch",
      "automerge": true
    },
    {
      "description": "Group minor and patch updates for Ansible Galaxy roles",
      "matchManagers": [
        "ansible-galaxy"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "ansible-galaxy minor/patch",
      "automerge": true
    },
    {
      "description": "Group minor and patch updates for GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github-actions minor/patch",
      "automerge": true
    },
    {
      "description": "Automerge minor and patch updates for pre-commit",
      "matchManagers": [
        "pre-commit"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "pre-commit minor/patch",
      "automerge": true
    }
  ]
}
