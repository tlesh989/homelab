#!/usr/bin/env bash
source_up_if_exists

unset TF_TOKEN
unset TF_TOKEN_app_terraform_io

# Capture Doppler output and check exit status
DOPPLER_OUTPUT=$(doppler secrets download -p homelab -c main --no-file --format env 2>&1)
DOPPLER_EXIT_CODE=$?

if [[ $DOPPLER_EXIT_CODE -ne 0 ]]; then
  echo "ERROR: Doppler secrets download failed with exit code $DOPPLER_EXIT_CODE" >&2
  echo "$DOPPLER_OUTPUT" >&2
  exit 1
fi

# Source the captured output
set -a
# shellcheck source=/dev/null
source <(echo "$DOPPLER_OUTPUT")
set +a

# Verify TF_TOKEN is set and non-empty
if [[ -z "${TF_TOKEN:-}" ]]; then
  echo "ERROR: TF_TOKEN is not set or empty after sourcing Doppler secrets" >&2
  exit 1
fi

# Only export when TF_TOKEN is present
export TF_TOKEN_app_terraform_io=$TF_TOKEN