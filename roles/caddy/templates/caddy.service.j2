# Managed by Ansible — do not edit manually
[Unit]
Description=Caddy reverse proxy
Documentation=https://caddyserver.com/docs/
After=network.target network-online.target
Requires=network-online.target

[Service]
Type=notify
User=caddy
Group=caddy
ExecStart=/usr/local/bin/caddy run --environ --config {{ caddy_install_dir }}/Caddyfile
ExecReload=/usr/local/bin/caddy reload --config {{ caddy_install_dir }}/Caddyfile --force
TimeoutStopSec=5s
LimitNOFILE=1048576
PrivateTmp=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_BIND_SERVICE
Environment=HOME={{ caddy_data_dir }}
Environment=XDG_DATA_HOME={{ caddy_data_dir }}

[Install]
WantedBy=multi-user.target
