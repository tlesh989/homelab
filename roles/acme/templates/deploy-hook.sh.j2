#!/usr/bin/env bash
# Managed by Ansible — runs after acme.sh issues or renews *.{{ acme_domain }}
# TLS deployment is now handled by Caddy (roles/caddy).
# acme.sh continues to issue/renew certs; this hook is a no-op.

log() { echo "[acme-deploy] $*"; }

log "cert renewed at {{ acme_cert_dir }} — Caddy handles deployment"
