global:
  scrape_interval: 60s
  evaluation_interval: 60s

scrape_configs:
  - job_name: node
    static_configs:
      - targets:
{% for host in groups['exporters'] | default([]) %}
        - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endfor %}

{% if groups['arr'] | default([]) | length > 0 %}
  - job_name: scraparr
    static_configs:
      - targets:
{% for host in groups['arr'] | default([]) %}
        - "{{ hostvars[host]['ansible_host'] }}:{{ scraparr_port }}"
{% endfor %}
{% endif %}

  - job_name: cadvisor
    static_configs:
      - targets:
          - "{{ hostvars['kaz.tlesh.xyz']['ansible_host'] }}:{{ cadvisor_port }}"
