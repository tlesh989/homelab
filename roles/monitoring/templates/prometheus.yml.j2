global:
  scrape_interval: 60s
  evaluation_interval: 60s

scrape_configs:
  - job_name: node
    static_configs:
      - targets:
{% for host in groups['exporters'] %}
        - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endfor %}

  - job_name: exportarr-sonarr
    static_configs:
      - targets:
        - "192.168.233.24:9707"

  - job_name: exportarr-radarr
    static_configs:
      - targets:
        - "192.168.233.24:9708"

  - job_name: exportarr-lidarr
    static_configs:
      - targets:
        - "192.168.233.24:9709"
