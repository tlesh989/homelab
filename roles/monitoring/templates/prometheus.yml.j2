global:
  scrape_interval: 60s
  evaluation_interval: 60s

scrape_configs:
  - job_name: node
    static_configs:
      - targets:
{% for host in groups['exporters'] | default([]) %}
        - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endfor %}

{% if groups['arr'] | default([]) | length > 0 %}
  - job_name: scraparr
    static_configs:
      - targets:
{% for host in groups['arr'] | default([]) %}
        - "{{ hostvars[host]['ansible_host'] }}:{{ scraparr_port }}"
{% endfor %}
{% endif %}

  - job_name: cadvisor
    static_configs:
      - targets:
{% for host in groups['kaz'] | default([]) %}
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ cadvisor_port }}"
{% endfor %}

  - job_name: pve
    static_configs:
      - targets:
{% for host in groups['proxmox'] | default([]) %}
          - "{{ hostvars[host]['ansible_host'] }}"
{% endfor %}
    metrics_path: /pve
    params:
      module: [default]
      cluster: ['1']
      node: ['1']
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
{% for host in groups['kaz'] | default([]) %}
      - target_label: __address__
        replacement: "{{ hostvars[host]['ansible_host'] }}:{{ pve_exporter_port }}"
{% endfor %}

  - job_name: truenas
    static_configs:
      - targets:
{% for host in groups['kaz'] | default([]) %}
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ truenas_exporter_port }}"
{% endfor %}

  - job_name: unifi
    static_configs:
      - targets:
{% for host in groups['kaz'] | default([]) %}
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ unpoller_port }}"
{% endfor %}

  - job_name: pihole
    static_configs:
      - targets:
{% for host in groups['kaz'] | default([]) %}
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ pihole_exporter_port }}"
{% endfor %}
