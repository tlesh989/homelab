---
# Managed by Ansible — do not edit manually
# Note: security_opt: apparmor=unconfined is required because this container runs inside an
# unprivileged LXC container. Docker cannot load the docker-default AppArmor profile in that context
# (apparmor_parser requires policy admin privileges), causing the container to fail on startup.
services:
  uptime-kuma:
    image: louislam/uptime-kuma:latest
    container_name: uptime-kuma
    security_opt:
      - apparmor=unconfined
    volumes:
      - "{{ uptime_kuma_data_path }}:/app/data"
    ports:
      - "{{ uptime_kuma_port }}:3001"
    restart: unless-stopped
