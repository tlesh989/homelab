#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="{{ minecraft_install_dir }}"
VERSION_FILE="${INSTALL_DIR}/.version"
PRESERVE_ITEMS=(
  worlds
  server.properties
  allowlist.json
  permissions.json
  valid_known_packs.json
)

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }

# Fetch latest x86_64 BDS download URL from Mojang
LATEST_URL=$(curl -fsSL --connect-timeout 10 --max-time 60 --retry 3 --retry-delay 5 \
  -H "Accept-Language: en-US,en" \
  -A "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 Chrome/120.0" \
  "https://www.minecraft.net/en-us/download/server/bedrock" \
  | grep -oP 'https://[^"]+bedrock-server-[0-9.]+\.zip' \
  | grep -v arm \
  | head -1)

if [[ -z "${LATEST_URL}" ]]; then
  log "ERROR: Failed to determine latest BDS URL" >&2
  exit 1
fi

LATEST_VERSION=$(echo "${LATEST_URL}" | grep -oP '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+')
INSTALLED_VERSION=$(cat "${VERSION_FILE}" 2>/dev/null || echo "0.0.0.0")

if [[ "$(printf '%s\n%s\n' "${INSTALLED_VERSION}" "${LATEST_VERSION}" | sort -V | tail -n1)" == "${INSTALLED_VERSION}" ]]; then
  log "Installed version (${INSTALLED_VERSION}) is >= latest discovered (${LATEST_VERSION}); skipping"
  exit 0
fi

log "Updating BDS: ${INSTALLED_VERSION} -> ${LATEST_VERSION}"

TMP_DIR=$(mktemp -d)
TMP_ZIP="${TMP_DIR}/bedrock-server-${LATEST_VERSION}.zip"
TMP_EXTRACT="${TMP_DIR}/extract"
TMP_PRESERVE="${TMP_DIR}/preserve"

cleanup() { rm -rf "${TMP_DIR}"; }
trap cleanup EXIT

log "Downloading ${LATEST_URL}"
curl -fsSL --connect-timeout 10 --max-time 300 --retry 3 --retry-delay 5 \
  -A "Mozilla/5.0 (X11; Linux x86_64)" -o "${TMP_ZIP}" "${LATEST_URL}"

mkdir -p "${TMP_EXTRACT}" "${TMP_PRESERVE}"
unzip -q "${TMP_ZIP}" -d "${TMP_EXTRACT}"

log "Stopping minecraft service"
systemctl stop minecraft
# Wait up to 30s for the service to fully stop before touching files
for i in $(seq 1 30); do
  systemctl is-active --quiet minecraft || break
  sleep 1
done
if systemctl is-active --quiet minecraft; then
  log "ERROR: minecraft service did not stop within 30s — aborting update" >&2
  exit 1
fi

# Backup preserved files after service has stopped
for item in "${PRESERVE_ITEMS[@]}"; do
  if [[ -e "${INSTALL_DIR}/${item}" ]]; then
    cp -a "${INSTALL_DIR}/${item}" "${TMP_PRESERVE}/${item}"
  fi
done

cp -a "${TMP_EXTRACT}/." "${INSTALL_DIR}/"

# Restore preserved files
for item in "${PRESERVE_ITEMS[@]}"; do
  if [[ -e "${TMP_PRESERVE}/${item}" ]]; then
    cp -a "${TMP_PRESERVE}/${item}" "${INSTALL_DIR}/${item}"
  fi
done

echo "${LATEST_VERSION}" > "${VERSION_FILE}"
chown -R minecraft:minecraft "${INSTALL_DIR}"

log "Starting minecraft service"
systemctl start minecraft

log "Update complete: ${LATEST_VERSION}"
