#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="{{ minecraft_install_dir }}"
if [[ -z "${INSTALL_DIR}" || "${INSTALL_DIR}" == "/" ]]; then
  echo "ERROR: refusing to update with unsafe INSTALL_DIR='${INSTALL_DIR}'" >&2
  exit 1
fi
VERSION_FILE="${INSTALL_DIR}/.version"
PRESERVE_ITEMS=(
  worlds
  server.properties
  allowlist.json
  permissions.json
  valid_known_packs.json
)

# All log output goes to stderr so command-substitution callers don't capture it.
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >&2; }

# ---------------------------------------------------------------------------
# get_latest_bds_url: query the Mojang download API for the latest Linux BDS
# zip URL.  The API endpoint is stable JSON — prefer this over HTML scraping.
# If the endpoint changes:
#   1. Check https://www.minecraft.net/en-us/download/server/bedrock to find
#      the new API via browser devtools (Network tab, filter: download/links)
#   2. Alternatively pin minecraft_bds_version in defaults/main.yml and set
#      minecraft_bds_download_url directly to skip the auto-update path.
# ---------------------------------------------------------------------------
get_latest_bds_url() {
  local url
  local attempt max_attempts=5
  local delay=5
  local response

  for attempt in $(seq 1 "${max_attempts}"); do
    log "Fetching BDS download links (attempt ${attempt}/${max_attempts})"
    response=$(curl -fsSL --connect-timeout 10 --max-time 30 \
      -H "Accept: application/json" \
      -A "Mozilla/5.0 (X11; Linux x86_64)" \
      "https://net-secondary.web.minecraft-services.net/api/v1.0/download/links" 2>&1) || {
        log "WARNING: curl failed on attempt ${attempt} — ${response:0:200}"
        sleep "${delay}"
        delay=$(( delay * 2 ))
        continue
      }

    url=$(echo "${response}" \
      | python3 -c "
import json, sys
data = json.load(sys.stdin)
links = data.get('result', {}).get('links', [])
for link in links:
    if link.get('downloadType') == 'serverBedrockLinux':
        print(link['downloadUrl'])
        break
" 2>/dev/null)

    if [[ -z "${url}" ]]; then
      log "WARNING: No serverBedrockLinux URL in API response on attempt ${attempt}"
      sleep "${delay}"
      delay=$(( delay * 2 ))
      continue
    fi

    if ! [[ "${url}" =~ ^https://[a-zA-Z0-9._/-]+bedrock-server-[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\.zip$ ]]; then
      log "ERROR: Extracted URL failed pattern validation: '${url}'" >&2
      return 1
    fi

    echo "${url}"
    return 0
  done

  log "ERROR: Could not determine latest BDS URL after ${max_attempts} attempts" >&2
  return 1
}

LATEST_URL=$(get_latest_bds_url)

LATEST_VERSION=$(echo "${LATEST_URL}" | grep -oP '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+')
INSTALLED_VERSION=$(cat "${VERSION_FILE}" 2>/dev/null || echo "0.0.0.0")

if [[ "$(printf '%s\n%s\n' "${INSTALLED_VERSION}" "${LATEST_VERSION}" | sort -V | tail -n1)" == "${INSTALLED_VERSION}" ]]; then
  log "Installed version (${INSTALLED_VERSION}) is >= latest discovered (${LATEST_VERSION}); skipping"
  exit 0
fi

log "Updating BDS: ${INSTALLED_VERSION} -> ${LATEST_VERSION}"

TMP_DIR=$(mktemp -d)
TMP_ZIP="${TMP_DIR}/bedrock-server-${LATEST_VERSION}.zip"
TMP_EXTRACT="${TMP_DIR}/extract"
TMP_PRESERVE="${TMP_DIR}/preserve"

cleanup() { rm -rf "${TMP_DIR}"; }
trap cleanup EXIT

log "Downloading ${LATEST_URL}"
curl -fsSL --connect-timeout 10 --max-time 300 --retry 3 --retry-delay 5 \
  -A "Mozilla/5.0 (X11; Linux x86_64)" -o "${TMP_ZIP}" "${LATEST_URL}"

# Verify archive integrity before touching the live install directory.
# Mojang does not publish a separate checksum file, so we validate that the
# zip is structurally sound.  This catches truncated downloads and obvious
# corruption before we stop the server and overwrite files.
log "Verifying archive integrity: ${TMP_ZIP}"
if ! unzip -t -q "${TMP_ZIP}" >/dev/null 2>&1; then
  log "ERROR: Archive integrity check failed — zip appears corrupt or truncated" >&2
  log "ERROR: Downloaded from: ${LATEST_URL}" >&2
  exit 1
fi
log "Archive integrity OK"

mkdir -p "${TMP_EXTRACT}" "${TMP_PRESERVE}"
unzip -q "${TMP_ZIP}" -d "${TMP_EXTRACT}"

log "Stopping minecraft service"
systemctl stop minecraft
# Wait up to 30s for the service to fully stop before touching files
for i in $(seq 1 30); do
  systemctl is-active --quiet minecraft || break
  sleep 1
done
if systemctl is-active --quiet minecraft; then
  log "ERROR: minecraft service did not stop within 30s — aborting update" >&2
  exit 1
fi

# If any subsequent step fails, attempt to restart the service before exiting
# so that a failed update doesn't leave the server permanently down.
restart_on_error() {
  local code=$?
  log "ERROR: update failed (exit ${code}) — attempting minecraft service restart"
  systemctl start minecraft || log "ERROR: failed to restart minecraft after update failure"
  exit "${code}"
}
trap restart_on_error ERR

# Disable ERR trap before mutating live install directory to prevent
# restart_on_error from booting a partial install if any step fails.
trap - ERR

# Backup preserved files after service has stopped
for item in "${PRESERVE_ITEMS[@]}"; do
  if [[ -e "${INSTALL_DIR}/${item}" ]]; then
    cp -a "${INSTALL_DIR}/${item}" "${TMP_PRESERVE}/${item}"
  fi
done

# Wipe install dir to prevent stale file drift from Mojang renames/removals,
# then copy the fresh extract.
find "${INSTALL_DIR}" -mindepth 1 -delete
cp -a "${TMP_EXTRACT}/." "${INSTALL_DIR}/"

# Restore preserved files
for item in "${PRESERVE_ITEMS[@]}"; do
  if [[ -e "${TMP_PRESERVE}/${item}" ]]; then
    cp -a "${TMP_PRESERVE}/${item}" "${INSTALL_DIR}/${item}"
  fi
done

echo "${LATEST_VERSION}" > "${VERSION_FILE}"
chown -R minecraft:minecraft "${INSTALL_DIR}"

# Re-enable ERR trap now that install directory is in a consistent state
trap restart_on_error ERR

trap - ERR  # clear error trap before the intentional service start

log "Starting minecraft service"
systemctl start minecraft

log "Update complete: ${LATEST_VERSION}"
